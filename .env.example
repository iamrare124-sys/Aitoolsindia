# ─── NICHE & SITE IDENTITY ───────────────────────────────────────
NICHE=aitoolsindia
SITE_NAME=aitoolsindia
LANGUAGE_MODE=english

# ─── AI ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── IMAGES ──────────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ─── SUPABASE (shared across all 10 sites) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── SECURITY ────────────────────────────────────────────────────
CRON_SECRET=your-secure-cron-secret-here
SITE_API_PASSWORD=your-secure-api-password-here

# ─── SITE ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aitoolsindia.in

# ─── ANALYTICS & ADS ─────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ─── LIMITS ──────────────────────────────────────────────────────
MAX_POSTS_PER_SITE=30

# ─── OPTIONAL ────────────────────────────────────────────────────
NEWS_API_KEY=
ALPHA_VANTAGE_KEY=
INDEX_NOW_KEY=your-indexnow-key
GOOGLE_SITE_VERIFICATION=your-google-verification-code
BING_SITE_VERIFICATION=your-bing-verification-code

# ─── ENV VARIABLE MAP ────────────────────────────────────────────
# NICHE               → config/site.config.js (loads niche config)
# SITE_NAME           → lib/supabase.js ALL queries (filters posts per site in shared DB)
# LANGUAGE_MODE       → config/site.config.js (english/hindi switch)
# GROQ_API_KEY        → lib/blog-generator.js → getGroq() (lazy init)
# PEXELS_API_KEY      → lib/image-fetcher.js
# UNSPLASH_ACCESS_KEY → lib/image-fetcher.js (fallback)
# NEXT_PUBLIC_SUPABASE_URL      → lib/supabase.js → getSupabase()
# NEXT_PUBLIC_SUPABASE_ANON_KEY → lib/supabase.js → getSupabase() (public reads)
# SUPABASE_SERVICE_ROLE_KEY     → lib/supabase.js → getSupabaseAdmin() (writes only)
# CRON_SECRET         → lib/security.js → verifyCronSecret()
# SITE_API_PASSWORD   → lib/security.js → verifyApiPassword()
# NEXT_PUBLIC_SITE_URL → app/[slug]/page.js, app/sitemap.js, app/robots.js, app/api/cron
# MAX_POSTS_PER_SITE  → lib/supabase.js → enforcePostLimit()
# NEXT_PUBLIC_GA4_ID  → app/layout.js (only loads if starts with G-)
# NEXT_PUBLIC_ADSENSE_ID → app/layout.js (only loads if starts with ca-pub-)
# INDEX_NOW_KEY       → app/api/indexnow/route.js
# GOOGLE_SITE_VERIFICATION → app/layout.js → metadata.verification
# BING_SITE_VERIFICATION   → app/layout.js → metadata.verification
